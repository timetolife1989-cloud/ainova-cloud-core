# ============================================
# AINOVA CLOUD CORE — Environment Variables
# Copy this file to .env and fill in values.
# ============================================

# ---- Database ----
DB_ADAPTER=mssql
# When running via docker-compose, use the service name as host:
DB_SERVER=localhost
DB_DATABASE=AinovaCore
DB_USER=sa
DB_PASSWORD=
DB_PORT=1433
DB_CONNECTION_TIMEOUT=30000
DB_REQUEST_TIMEOUT=30000
DB_POOL_MIN=2
DB_POOL_MAX=10

# ---- Docker (used by docker-compose.yml) ----
# SA_PASSWORD must meet SQL Server complexity requirements:
#   min 8 chars, uppercase + lowercase + digit + symbol
SA_PASSWORD=AinovaSecret1!

# ---- Auth ----
AUTH_ADAPTER=session
# Must be at least 32 characters — change before production!
SESSION_SECRET=change-me-minimum-32-characters-long

# ---- File uploads (runtime directory, outside .next/) ----
# Docker default: /ainova-uploads (mounted volume)
# Windows local default: C:\AinovaUploads
UPLOAD_DIR=/ainova-uploads

# ---- Feature flags ----
FE_LOGIN_RATE_LIMIT=true
FE_LOGIN_AUDIT=true

# ---- App ----
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=Ainova Cloud Core
APP_PORT=3000
